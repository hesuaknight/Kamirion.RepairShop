@page
@model Kamirion.RepairShop.Web.Areas.Auth.Pages.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Kamirion.RepairShop.Web.Modules.Identity.IdentityResources> Localizer

@{
    ViewData["Title"] = Localizer["Login_Title"];
    var hasModelErrors = ViewData.ModelState.ContainsKey(string.Empty)
                      && ViewData.ModelState[string.Empty]!.Errors.Count > 0;
}

<div style="display:flex; justify-content:center; width:100%;">
    <div style="max-width:400px; width:100%; background:var(--rs-bg-surface); border:1px solid var(--rs-border); border-radius:var(--rs-radius-xl); padding:2rem;">

        <div style="text-align:center; margin-bottom:1.5rem;">
            <div style="font-size:2rem; color:var(--rs-emerald); line-height:1; margin-bottom:.5rem;">⬡</div>
            <div style="font-size:18px; font-weight:600; color:var(--rs-text-primary);">RepairShop</div>
        </div>

        @if (hasModelErrors)
        {
            <div class="rs-alert rs-alert-error" role="alert">
                <i class="ti ti-alert-circle" aria-hidden="true"></i>
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="rs-field">
                <label class="rs-label" asp-for="Input.Email">@Localizer["Login_Email_Label"]</label>
                <input class="rs-input" asp-for="Input.Email" type="email" autocomplete="username" />
                <span class="rs-field-error" asp-validation-for="Input.Email"></span>
            </div>

            <div class="rs-field">
                <label class="rs-label" asp-for="Input.Password">@Localizer["Login_Password_Label"]</label>
                <input class="rs-input" asp-for="Input.Password" type="password" autocomplete="current-password" />
                <span class="rs-field-error" asp-validation-for="Input.Password"></span>
            </div>

            <button type="submit" class="btn btn-rs-primary btn-lg w-100" style="margin-top:.5rem;">
                @Localizer["Login_Submit_Button"]
            </button>
        </form>

    </div>
</div>
